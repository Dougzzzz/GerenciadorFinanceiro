# Top-level editorconfig file
root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.cs]
# Organização de Usings
dotnet_separate_import_directive_groups = false
dotnet_sort_system_usings_first = true

# Regras de Estilo de Código C#
csharp_style_expression_bodied_methods = true:suggestion
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = true:suggestion
csharp_style_expression_bodied_properties = true:suggestion
csharp_style_expression_bodied_accessors = true:suggestion
csharp_style_expression_bodied_lambdas = true:suggestion
csharp_style_expression_bodied_local_functions = true:suggestion

# Ajustes de Nomenclatura e Estilo (Desativando regras pedantes)
dotnet_diagnostic.SA1200.severity = none       # Usings fora do namespace
dotnet_diagnostic.SA1633.severity = none       # Cabeçalho de arquivo
dotnet_diagnostic.SA1101.severity = none       # Uso obrigatório de 'this.'
dotnet_diagnostic.SA1309.severity = none       # Proibição de '_' em campos privados
dotnet_diagnostic.SA1600.severity = none       # Exigência de comentários XML (documentação)
dotnet_diagnostic.SA0001.severity = none       # Avisos sobre documentação XML
dotnet_diagnostic.SA1516.severity = none       # Linhas em branco entre elementos
dotnet_diagnostic.SA1028.severity = none       # Espaços em branco no final da linha
dotnet_diagnostic.SA1201.severity = none       # Ordem de elementos (ex: enum após classe)
dotnet_diagnostic.SA1502.severity = none       # Elementos em uma única linha
dotnet_diagnostic.SA1117.severity = none       # Parâmetros na mesma linha ou linhas separadas
dotnet_diagnostic.SA1208.severity = none       # Ordem de usings do sistema

# Regras do IDE (Microsoft)
dotnet_diagnostic.IDE0008.severity = none       # Preferir var ou tipo explícito
dotnet_diagnostic.IDE0058.severity = none       # Valor da expressão não usado
dotnet_diagnostic.IDE0290.severity = none       # Sugestão de Construtor Primário
dotnet_diagnostic.IDE0046.severity = none       # Simplificar if
dotnet_diagnostic.IDE0011.severity = none       # Exigir chaves em ifs curtos
dotnet_diagnostic.SA1649.severity = none       # Erro do analisador com Records
dotnet_diagnostic.CA1707.severity = none       # Permitir underscores em nomes (comum em testes)
dotnet_diagnostic.SA1010.severity = none       # Espaço antes de colchetes em collection expressions

# Nomenclatura (Padrão PascalCase para classes, métodos, etc)
dotnet_naming_rule.interface_should_be_begun_with_i.severity = suggestion
dotnet_naming_rule.interface_should_be_begun_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_begun_with_i.style = begun_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_style.begun_with_i.required_prefix = I
dotnet_naming_style.begun_with_i.capitalization = pascal_case

# Severidade de Estilo
dotnet_analyzer_diagnostic.category-Style.severity = warning
